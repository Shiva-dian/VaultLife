# ─── Server ───────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── PostgreSQL (Docker) ──────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vaultlife_db
DB_USER=vaultlife_user
DB_PASSWORD=vaultlife_secret_2025
DB_SSL=false

# ─── JWT ─────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── OTP ─────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# ─── Email (Nodemailer / Gmail) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=VaultLife <noreply@vaultlife.in>

# ─── SMS (Twilio) — optional ──────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Frontend URL (CORS) ─────────────────────
CLIENT_URL=http://localhost:5173

# ─── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
