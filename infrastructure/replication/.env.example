# ============================================================
# .env — VaultLife Replication Environment Variables
# Copy to infrastructure/replication/.env and fill in values
# NEVER commit this file to git
# ============================================================

# ── PRIMARY SERVER ────────────────────────────────────────────
DB_PASSWORD=vaultlife_secret_2025_change_me
REPLICATOR_PASSWORD=replicator_secret_change_me
MONITOR_PASSWORD=monitor_secret_change_me

# ── STANDBY SERVER ────────────────────────────────────────────
# IP or hostname of the PRIMARY server (as seen from standby)
# e.g. AWS: ec2-13-235-xx-xx.ap-south-1.compute.amazonaws.com
# e.g. GCP: 10.160.0.2
PRIMARY_HOST=PRIMARY_SERVER_IP_OR_HOSTNAME
PRIMARY_PORT=5432

# ── REGION LABELS ─────────────────────────────────────────────
PRIMARY_REGION=ap-south-1         # e.g. Mumbai (UTC+5:30, Day)
STANDBY_REGION=sa-east-1          # e.g. São Paulo (UTC-3, Night)

# ── BACKUP SETTINGS ───────────────────────────────────────────
BACKUP_DIR=/backups
BACKUP_RETAIN=30                   # Keep 30 daily backups

# ── ALERT WEBHOOK (optional) ─────────────────────────────────
# Slack: https://hooks.slack.com/services/xxx/yyy/zzz
# Teams: https://outlook.office.com/webhook/...
ALERT_WEBHOOK_URL=
